{
  "expo": {
    "name": "Cozy Quotes",
    "slug": "cozy-quotes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cozyquotes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F0E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nickkupriyanov.cozyquotes"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "./plugins/withCozyQuotesIos",
        {
          "appGroupIdentifier": "group.com.nickkupriyanov.cozyquotes",
          "widgetBundleIdentifier": "com.nickkupriyanov.cozyquotes.widget"
        }
      ]
    ]
  }
}
